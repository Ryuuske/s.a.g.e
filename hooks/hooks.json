{
  "description": "sage session-end and pre-compact hooks: orchestrator-gated emergency drawer fallback (~/.sage/current_wing + last_keeper_dispatch sentinels) + non-blocking autonomy reporting-contract evaluator (ADR-0066, in-flight runs only).",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop.py\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/autonomy_reporting_eval.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/precompact.py\"",
            "timeout": 90
          }
        ]
      }
    ]
  }
}
